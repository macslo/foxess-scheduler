# ── Secrets — copy this file to .env and fill in your values ─────────────────
# .env is in .gitignore and must NEVER be committed to the repo.

# FoxESS Cloud API key
# Get it at: foxesscloud.com -> Avatar -> Personal Centre -> API Management
FOXESS_API_KEY=your_api_key_here

# Device serial number — leave as "auto" to detect automatically
FOXESS_SN=auto

# Your location for cloud cover forecast (decimal degrees)
# Default in config.py is Gliwice, Poland — override here with your exact address
FOXESS_LAT=50.2849
FOXESS_LON=18.6717

# Discord webhook URL for notifications (optional)
# Create one: Discord channel → Edit → Integrations → Webhooks → New Webhook → Copy URL
# Leave blank to disable Discord notifications
FOXESS_DISCORD_WEBHOOK=
